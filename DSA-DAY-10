// Day 10: LeetCode 2677 - Chunk Array
// Language: JavaScript
//
// Problem:
// Given an array arr and a chunk size size, return a chunked array.
// A chunked array contains subarrays, each of length 'size'. The last subarray
// may be shorter if the total elements aren't perfectly divisible by 'size'.

// EX 1 
// Input: arr = [1,2,3,4,5], size = 1
// Output: [[1],[2],[3],[4],[5]]
// Explanation: The arr has been split into subarrays each with 1 element.

/**
 * @param {Array} arr
 * @param {number} size
 * @return {Array}
 */
var chunk = function (arr, size) {
    const chunkedArray = [];

    // Loop through the array, skipping forward by the 'size' amount each time
    for (let i = 0; i < arr.length; i += size) {
        // Slice a chunk from the current index 'i' up to 'i + size' and push it
        chunkedArray.push(arr.slice(i, i + size));
    }

    return chunkedArray;
};