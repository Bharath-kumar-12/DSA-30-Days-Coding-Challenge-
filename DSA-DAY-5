// Day 5: LeetCode 2704 - To Be Or Not To Be
// Language: JavaScript
//
// Example 1:

// Input: func = () => expect(5).toBe(5)
// Output: {"value": true}
// Explanation: 5 === 5 so this expression returns true.

// Explanation

//1. You load a starting item into the scanner: expect(5)
// 2. The scanner hands you a mini toolbox with two buttons: .toBe() and .notToBe()
// 3. You press a button to test your item against a target value:
//
// Errors:
// In JavaScript, 'throw new Error("message")' is used to intentionally stop execution
// and flag a failure when code doesn't behave as expected.

/**
 * @param {string} val
 * @return {Object}
 */
var expect = function(val) {
    return {
        // Method 1: Check if two values are strictly equal
        toBe: function(otherVal) {
            if (val === otherVal) {
                return true;
            } else {
                throw new Error("Not Equal");
            }
        },
        
        // Method 2: Check if two values are NOT equal
        notToBe: function(otherVal) {
            if (val !== otherVal) {
                return true;
            } else {
                throw new Error("Equal");
            }
        }
    };
};