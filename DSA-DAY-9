// Day 9: LeetCode 2667 - Create Hello World Function
// Language: JavaScript
//
// Problem:
// Write a function createHelloWorld. It should return a new function that always returns "Hello World".
// 
// Example 1:
// Input: args = []
// Output: "Hello World"
// Explanation:
// const f = createHelloWorld();
// f(); // "Hello World"

/**
 * @param {Array} args
 * @return {Function}
 */
var createHelloWorld = function () {
    return function (...args) {
        return "Hello World";
    };
};