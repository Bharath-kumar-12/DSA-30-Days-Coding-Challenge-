// Day 11: LeetCode 2715 - Timeout Cancellation
// Language: JavaScript
//
// Problem:
// Given a function fn, an array of arguments args, and a timeout t in milliseconds, 
// return a cancel function cancelFn. The execution of fn should be delayed by t ms.
// If cancelFn is called before t ms, fn should never execute. Otherwise, fn executes normally. as per question given in the leetcode
//
// Example 1:
// Input: fn = (x) => x * 5, args = [2], t = 20
// Output: [{"time": 20, "returned": 10}]

/**
 * @param {Function} fn
 * @param {Array} args
 * @param {number} t
 * @return {Function}
 */
var cancellable = function (fn, args, t) {
    // Step 1: Schedule the function execution after 't' milliseconds
    const timerId = setTimeout(() => {
        fn(...args);
    }, t);

    // Step 2: Return the cancel function that clears the timeout before it fires
    return function () {
        clearTimeout(timerId);
    };
};