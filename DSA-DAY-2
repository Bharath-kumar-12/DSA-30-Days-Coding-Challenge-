// Day 2 : LeetCode 2692 - FUNCTION COMPOSTION 
// Problem : COMPOSTION basic rule is the right to left approach (Right -> Left) 
//given problem index 2 *4 = 8, index 1 8*8 = 64, index 0 64+1 = 65 this should be output of the problem
// language : JavaScript
// For loop used to iterate through the functions array from right to left and apply each function to the result of the previous one, starting with the initial value x.

//  example 1 
//  Input: functions = [x => x + 1, x => x * x, x => 2 * x], x = 4
//  Output: 65
//  Explanation:
//  Evaluating from right to left ...
//  Starting with x = 4.
//  2 * (4) = 8
//  (8) * (8) = 64
//  (64) + 1 = 65 

/**
 * @param {Function[]} functions
 * @return {Function}
 */
var compose = function(functions) {  // closures function for reference 
    return function(x) {
        // right to left approach (Right -> Left)
        for (let i = functions.length - 1; i >= 0; i--) {
            // Grab the function at index 'i' and run it with current 'x'
            x = functions[i](x); 
            
            
        }
        
        // Return the final transformed number
        return x;
    };
};